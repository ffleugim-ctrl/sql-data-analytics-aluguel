-- 4. CONSULTA PARA O DASHBOARD (PEOPLE ANALYTICS)
-- Esta query gera os percentuais exatos para o seu gráfico de rosca
SELECT 
    Status_Pagamento,
    COUNT(*) AS Total_Casas,
    CAST(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM Imoveis) AS DECIMAL(10,2)) AS Percentual
FROM (
    SELECT 
        I.id_imovel,
        CASE 
            WHEN MAX(P.juros_aplicados) > 0 THEN 'Pagou com Atraso'
            WHEN MAX(P.valor_pago) IS NULL THEN 'Inadimplente'
            ELSE 'Pagou em Dia'
        END AS Status_Pagamento
    FROM Imoveis I
    LEFT JOIN Pagamentos P ON I.id_imovel = P.id_imovel 
    AND P.mes_referencia = '2025-03-01'
    GROUP BY I.id_imovel
) AS Subconsulta
GROUP BY Status_Pagamento;
GO

