-- 1. CRIAÇÃO DO AMBIENTE
USE master;
GO

-- Apaga o banco se ele já existir para evitar erros de duplicata
IF EXISTS (SELECT * FROM sys.databases WHERE name = 'GestaoAluguel')
    DROP DATABASE GestaoAluguel;
GO

CREATE DATABASE GestaoAluguel;
GO

USE GestaoAluguel;
GO

-- 2. CRIAÇÃO DAS TABELAS
-- Tabela de Imóveis (Cadastro das casas)
CREATE TABLE Imoveis (
    id_imovel INT PRIMARY KEY IDENTITY(1,1),
    tipo_imovel VARCHAR(50), -- 'Padrao' ou 'Luxo'
    endereco VARCHAR(100),
    valor_base DECIMAL(10, 2)
);
GO

-- Tabela de Pagamentos (Histórico mensal)
CREATE TABLE Pagamentos (
    id_pagamento INT PRIMARY KEY IDENTITY(1,1),
    id_imovel INT,
    mes_referencia DATE,
    data_pagamento DATE,
    valor_pago DECIMAL(10, 2),
    juros_aplicados DECIMAL(10, 2),
    CONSTRAINT FK_Imovel FOREIGN KEY (id_imovel) REFERENCES Imoveis(id_imovel)
);
GO

